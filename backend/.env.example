# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/taskflow

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:4000

# RSA Keys for Credential Encryption
# Generate these by running: npm run generate-keys
# Copy the output and paste below (keep the quotes)
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
