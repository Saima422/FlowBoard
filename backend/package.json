{
  "name": "flowboard-api",
  "version": "1.0.0",
  "description": "FlowBoard - Task management platform backend with Express and AWS Lambda",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/lambda.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc",
    "build:lambda": "npm run build && node scripts/package-lambda.js",
    "start": "node dist/server.js",
